generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// 素材分类
enum Category {
  scene
  tileset
  character
  prop
}

enum JobStatus {
  queued
  running
  done
  failed
}

enum AssetStatus {
  draft
  approved
  rejected
}

/// 风格预设 —— 系统核心，把视觉哲学固化成可复用对象，对抗风格漂移
model StylePreset {
  id             String   @id @default(cuid())
  name           String
  description    String?  @db.Text
  category       Category
  provider       String   @default("draw-things")
  /// Style Bible 锁定层: { style, material, lighting, consistency, quality } —— 单次生成不可改写
  styleBible     Json
  /// 工业级负面提示词（锁定）
  negativePrompt String   @db.Text
  /// 暴露的变量层与受控词表: { angles: string[], poses: string[], allowFreeSubject: boolean, defaultAngle?, defaultPose? }
  variableSlots  Json
  /// 锁定的生成参数 (steps, guidance, width, height, sampler...) —— 单次任务不可覆盖
  lockedParams   Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  jobs   GenerationJob[]
  assets Asset[]

  @@index([category])
  @@index([deletedAt])
}

/// 一次批量生成
model GenerationJob {
  id        String    @id @default(cuid())
  /// 生成标题
  name      String
  presetId  String
  preset    StylePreset @relation(fields: [presetId], references: [id], onDelete: Cascade)
  /// 本次实际配置: { prompt, negativePrompt, width, height, steps, guidanceScale, seed }
  variables Json
  count     Int       @default(1)
  /// 已完成图片数，进度 = completed / count
  completed Int       @default(0)
  status    JobStatus @default(queued)
  error     String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  assets Asset[]

  @@index([presetId])
  @@index([status])
  @@index([deletedAt])
}

/// 单个素材
model Asset {
  id          String      @id @default(cuid())
  jobId       String?
  job         GenerationJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)
  presetId    String?
  preset      StylePreset?   @relation(fields: [presetId], references: [id], onDelete: SetNull)
  category    Category
  status      AssetStatus @default(draft)
  /// 相对 ASSETS_DIR 的存储 key
  storageKey  String
  thumbKey    String?
  width       Int
  height      Int
  /// 复现信息: seed, 实际 prompt, provider 参数
  meta        Json
  tags        Json?
  createdAt   DateTime    @default(now())
  deletedAt   DateTime?

  @@index([category])
  @@index([status])
  @@index([jobId])
  @@index([deletedAt])
}

/// 用户设置 —— 按用户存储，data 内按 section 分组（provider / generation / appearance...）
model UserSettings {
  id        String   @id @default(cuid())
  /// 当前无鉴权，固定单用户标识；将来接入鉴权时映射真实用户
  userId    String   @unique
  /// 分 section 的设置：{ provider: {...}, generation: {...}, appearance: {...} }
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
